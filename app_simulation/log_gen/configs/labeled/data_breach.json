{
  "log_count": 1000,
  "time_increment_seconds": [2, 8],
  "process_id_range": [6000, 7000],
  "slot_range": [1, 10],
  "incident_probability": 0.3,
  "error_probability": 0.4,
  "incident_duration_logs": [5, 15],
  "incident_types": [
    "permission_denied",
    "auth_failure"
  ],
  "log_type_weights": {
    "normal": 0.1,
    "error": 0.2,
    "mod_jk_worker_init": 0.0,
    "mod_jk_worker_error": 0.05,
    "jk2_child_init": 0.0,
    "jk2_child_error": 0.05,
    "client_directory_forbidden": 0.35,
    "client_file_not_found": 0.25,
    "system_notice": 0.0
  },
  "client_ip_ranges": ["suspicious", "public"],
  "forbidden_paths": [
    "/var/www/html/database/",
    "/var/www/html/backup/customers.sql",
    "/var/www/html/.env",
    "/var/www/html/config/database.yml",
    "/var/www/html/uploads/private/"
  ],
  "_description": "Утечка данных - попытки доступа к конфиденциальной информации"
}
